# Javits Center — Campus Companion
# -----------------------------------------------------------------------------
# Copy this file to .env.local and fill in real values for local dev.
# Vercel reads the same keys from Project Settings → Environment Variables.
# Anything prefixed NEXT_PUBLIC_* is exposed to the browser bundle.
# -----------------------------------------------------------------------------

# --- App identity --------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Javits Center"
NEXT_PUBLIC_APP_ENV="development"   # development | preview | production

# --- Cisco Spaces (wayfinding) -------------------------------------------
# Leave blank in prototype; CiscoSpacesAdapter falls back to seed data.
CISCO_SPACES_TENANT_ID=
CISCO_SPACES_API_KEY=
CISCO_SPACES_BASE_URL="https://dnaspaces.io/api"

# --- Momentous (CRM / marketing leads) -----------------------------------
# Stub until the contract closes. MomentousAdapter no-ops without these.
MOMENTOUS_API_KEY=
MOMENTOUS_LIST_ID=
MOMENTOUS_BASE_URL=

# --- Cultivated (surveys / kiosks) ---------------------------------------
# Used by feature flag to toggle deep-link survey handoff.
CULTIVATED_DEEPLINK_BASE=

# --- Notifications (web push) --------------------------------------------
# Generate VAPID keys when web push is wired (next-pwa or hand-rolled SW).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:tech@javitscenter.com"

# --- Payments (Quiet Cove checkout) --------------------------------------
# Decision deferred. Stripe is the likely target; Square is a fallback.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Analytics -----------------------------------------------------------
# In-memory analytics by default. Wire to a real sink later (PostHog, GA4, etc).
NEXT_PUBLIC_ANALYTICS_KEY=
