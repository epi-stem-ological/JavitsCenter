{
  "name": "javits-wayfinder",
  "version": "0.1.0",
  "private": true,
  "description": "Prototype indoor wayfinding app for a large convention-center venue, built so a future Cisco Spaces native SDK integration can replace mocked providers.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc -b",
    "typecheck:clean": "tsc -b --clean",
    "mobile": "npm run -w @javits/mobile start",
    "web": "npm run -w @javits/web dev",
    "lint:cisco-leak": "node scripts/check-cisco-leak.js"
  },
  "devDependencies": {
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=18.18"
  }
}
