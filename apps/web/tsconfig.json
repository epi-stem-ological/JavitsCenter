{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "es2017",
    "module": "esnext",
    "jsx": "preserve",
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "outDir": "dist",
    "composite": true,
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }]
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"],
  "references": [
    { "path": "../../packages/domain" },
    { "path": "../../packages/providers" },
    { "path": "../../packages/mock-data" }
  ]
}
